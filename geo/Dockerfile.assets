FROM alpine:latest@sha256:25109184c71bdad752c8312a8623239686a9a2071e8825f20acb8f2198c3f659 AS builder

ARG BASE_URL=http://localhost:5173

WORKDIR /assets

COPY fonts /assets/fonts
COPY sprites /assets/sprites
COPY styles /assets/styles

RUN set -eux; \
    sanitized_base_url="$(printf '%s' "${BASE_URL}" | sed 's:/*$::')"; \
    for style in /assets/styles/*.json; do \
    sed -i "s|http://localhost:5173|${sanitized_base_url}|g" "${style}"; \
    done

FROM scratch

COPY --from=builder /assets/fonts /fonts
COPY --from=builder /assets/sprites /sprites
COPY --from=builder /assets/styles /styles