		"@sveltejs/vite-plugin-svelte": "7.0.0",
		"@tailwindcss/forms": "0.5.11",
		"@trivago/prettier-plugin-sort-imports": "6.0.2",
		"@types/d3-scale": "4.0.9",
		"@types/d3-shape": "3.1.8",
		"@types/d3-time": "3.0.4",
		"@types/eslint": "9.6.1",
		"@types/node": "25.6.0",
		"@vitest/browser-playwright": "4.1.5",
		"eslint": "10.2.1",
