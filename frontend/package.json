		"svelte-maplibre-gl": "1.0.3",
		"tailwindcss": "4.2.4",
		"typescript": "6.0.3",
		"typescript-eslint": "8.59.0",
		"vite": "8.0.9",
		"vitest": "4.1.5",
		"vitest-browser-svelte": "2.1.1"
	},
