  "db_name": "PostgreSQL",
  "query": "\n            INSERT INTO static.shape (id, source, geom, data)\n            SELECT id, source, ST_SetSRID(geom, 4326), data FROM UNNEST($1::text[], $2::source_enum[], $3::geometry[], $4::jsonb[])\n                AS t(id, source, geom, data)\n            ON CONFLICT (id, source) DO UPDATE SET\n                geom = EXCLUDED.geom,\n                data = EXCLUDED.data\n            ",
